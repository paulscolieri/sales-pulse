function getMetaAdInsights() {
  const scriptProps = PropertiesService.getScriptProperties();
  const accessToken = scriptProps.getProperty("META_ACCESS_TOKEN");
  const adAccountId = scriptProps.getProperty("META_AD_ACCOUNT_ID"); // e.g., "act_1234567890"
  const apiVersion = "v18.0";
  const url = `https://graph.facebook.com/${apiVersion}/${adAccountId}/insights`;

  // Set yesterday’s date range
  const today = new Date();
  const yesterday = new Date(today);
  yesterday.setDate(today.getDate() - 1);
  const since = Utilities.formatDate(yesterday, Session.getScriptTimeZone(), "yyyy-MM-dd");
  const until = since;

  const timeRange = JSON.stringify({ since, until });

  const fields = [
    "campaign_id", "campaign_name",
    "adset_id", "adset_name",
    "ad_id", "ad_name",
    "impressions", "clicks", "spend", "cpm", "cpc", "ctr",
    "actions", "action_values"
  ].join(",");

  const params = {
    method: "get",
    muteHttpExceptions: true,
    headers: {
      Authorization: `Bearer ${accessToken}`
    }
  };

  const query = [
    `fields=${encodeURIComponent(fields)}`,
    `time_range=${encodeURIComponent(timeRange)}`,
    `level=adset`,
    `time_increment=1`
  ].join("&");

  const fullUrl = `${url}?${query}`;
  const res = UrlFetchApp.fetch(fullUrl, params);
  const json = JSON.parse(res.getContentText());

  if (!json.data) {
    Logger.log("❌ Error fetching insights: " + res.getContentText());
    return [];
  }

  // Parse actions to extract purchases and purchase ROAS
  const cleanResults = json.data.map(row => {
    const actions = parseActions(row.actions || []);
    const values = parseActions(row.action_values || []);

    return {
      date: since,
      campaign_name: row.campaign_name || "",
      adset_name: row.adset_name || "",
      ad_name: row.ad_name || "",
      impressions: row.impressions || 0,
      clicks: row.clicks || 0,
      spend: parseFloat(row.spend || 0),
      cpm: parseFloat(row.cpm || 0),
      cpc: parseFloat(row.cpc || 0),
      ctr: parseFloat(row.ctr || 0),
      purchases: actions.purchase || 0,
      roas: values.purchase || 0
    };
  });

  Logger.log(`✅ Pulled ${cleanResults.length} ad rows for ${since}`);
  return cleanResults;
}

function parseActions(arr) {
  return arr.reduce((map, obj) => {
    if (obj.action_type && obj.value) {
      map[obj.action_type] = parseFloat(obj.value);
    }
    return map;
  }, {});
}
